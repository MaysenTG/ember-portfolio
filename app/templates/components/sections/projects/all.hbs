<section class="section" id="projects">
  <div class="container">
    <div class="text-center mb-2">
      <span class="section-label">Portfolio</span>
      <h2 class="section-title">My projects</h2>
      <p class="section-lead mx-auto">
        From ecommerce stores to URL shorteners and static site generators — here are some things I've built. My key
        strengths are Ruby on Rails, database development, and Javascript/Typescript.
      </p>
    </div>
    <ul class="project__list">
      {{#each this.projects as |project|}}
        <Sections::Projects::ProjectCard @project={{project}} />
      {{/each}}
    </ul>
  </div>
</section>
