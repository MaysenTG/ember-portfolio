<section class="section section--light" id="about">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <span class="section-label">About me</span>
        <h2 class="section-title">Building performant web apps with care</h2>
        <p class="about__text">
          I'm a full stack developer with a passion for building performant and dynamic web apps. I work as an
          intermediate developer at Henry Schein One where I lead large-scale projects, mentor junior developers, and
          contribute to onboarding and technical documentation.
        </p>
        <p class="about__text">
          In my free time I exercise and work towards my helicopter pilot license. My main focus spans frontend and
          backend, with particular skill in user experiences and RESTful APIs.
        </p>
        <div class="skills">
          {{#each this.skills as |skill|}}
            <span class="skill-tag">{{skill}}</span>
          {{/each}}
        </div>
      </div>
      <div class="col-lg-6">
        <div class="about__highlight">
          <div class="about__highlight-item">
            <div class="about__highlight-icon">
              <i class="bi bi-code-slash"></i>
            </div>
            <div class="about__highlight-text">
              <strong>Full Stack Development</strong>
              <span>Frontend, backend, and everything in between</span>
            </div>
          </div>
          <div class="about__highlight-item">
            <div class="about__highlight-icon">
              <i class="bi bi-people"></i>
            </div>
            <div class="about__highlight-text">
              <strong>Team Leadership</strong>
              <span>Mentoring juniors and leading large-scale projects</span>
            </div>
          </div>
          <div class="about__highlight-item">
            <div class="about__highlight-icon">
              <i class="bi bi-cloud"></i>
            </div>
            <div class="about__highlight-text">
              <strong>Cloud Architecture</strong>
              <span>Google Cloud and scalable infrastructure</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
